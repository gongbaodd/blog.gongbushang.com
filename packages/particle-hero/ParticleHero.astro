---
import ParticleHeroReact from "./ParticleHero.tsx";
import { Content } from "@/packages/hero/fragments/description.mdx";
import { Content as TitleContent } from "@/packages/hero/fragments/title.mdx";
import { loadUmapPosts } from "./loadUmapPosts";

interface IGalleryImageProp {
  url: string;
  traceSvg?: string;
  colorSet?: {
    bgColor: string;
    titleColor: string;
  };
}

interface Props {
  galleryImage?: IGalleryImageProp;
}

const { galleryImage } = Astro.props;

const posts = loadUmapPosts();
---

<ParticleHeroReact posts={posts} galleryImage={galleryImage} client:load>
  <TitleContent slot="title" />
  <Content slot="description" />
</ParticleHeroReact>
