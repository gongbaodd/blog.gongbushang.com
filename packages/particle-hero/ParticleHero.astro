---
import ParticleHero from "./ParticleHero.tsx";
import { Content } from "@/packages/hero/fragments/description.mdx";
import { readPostMetadata } from "@/packages/utils/post";

const posts = (readPostMetadata() ?? [])
  .filter(
    (entry): entry is typeof entry & { umap2D: [number, number] } =>
      entry.id != null && entry.umap2D != null,
  )
  .map(({ id, href, title, date, category, umap2D }) => ({
    id,
    href,
    title,
    date,
    category,
    umap2D,
  }))
  .sort(
    (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
  );
---

<ParticleHero posts={posts} client:load>
  <Content />
</ParticleHero>
